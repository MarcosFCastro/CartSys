<?xml version="1.0" encoding="utf-8" ?>
<!--
  NLog 4.x — ERP Financeiro
  Arquivo de configuração de logging.
  Coloque este arquivo na pasta de saída (bin/) ou defina Build Action = Content / Copy Always.
  Referência: https://nlog-project.org/config/
-->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/nlog-internal.log">

  <!-- ===================================================================
       Variáveis globais
       =================================================================== -->
  <variable name="logDir" value="${basedir}/logs" />
  <variable name="appName" value="ERPFinanceiro" />

  <!-- ===================================================================
       Targets (destinos de log)
       =================================================================== -->
  <targets async="true">

    <!-- ----------------------------------------------------------------
         1. Arquivo diário — log geral da aplicação
         Gira a cada dia. Mantém os últimos 30 arquivos (aprox. 1 mês).
         ---------------------------------------------------------------- -->
    <target xsi:type="File"
            name="fileDaily"
            fileName="${logDir}/${appName}_${date:format=yyyy-MM-dd}.log"
            archiveFileName="${logDir}/archive/${appName}_{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            archiveDateFormat="yyyy-MM-dd"
            maxArchiveFiles="30"
            encoding="utf-8"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message}${onexception:${newline}${exception:format=tostring}}" />

    <!-- ----------------------------------------------------------------
         2. Arquivo dedicado para INTEGRAÇÕES REST
         Registra chamadas e respostas entre os módulos (diagnóstico
         de idempotência, retries e callbacks).
         ---------------------------------------------------------------- -->
    <target xsi:type="File"
            name="fileIntegracao"
            fileName="${logDir}/${appName}_integracao_${date:format=yyyy-MM-dd}.log"
            archiveFileName="${logDir}/archive/${appName}_integracao_{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            archiveDateFormat="yyyy-MM-dd"
            maxArchiveFiles="15"
            encoding="utf-8"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message}${onexception:${newline}${exception:format=tostring}}" />

    <!-- ----------------------------------------------------------------
         3. Console (útil durante dev / debug da self-hosted API)
         ---------------------------------------------------------------- -->
    <target xsi:type="ColoredConsole"
            name="console"
            layout="${time} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message}${onexception: | ERRO: ${exception:format=message}}"
            useDefaultRowHighlightingRules="true">
      <highlight-row condition="level == LogLevel.Debug"   foregroundColor="Gray" />
      <highlight-row condition="level == LogLevel.Info"    foregroundColor="White" />
      <highlight-row condition="level == LogLevel.Warn"    foregroundColor="Yellow" />
      <highlight-row condition="level == LogLevel.Error"   foregroundColor="Red" />
      <highlight-row condition="level == LogLevel.Fatal"   foregroundColor="Red" backgroundColor="White" />
    </target>

    <!-- ----------------------------------------------------------------
         4. Target nulo — descarta logs abaixo do limiar sem custo
         ---------------------------------------------------------------- -->
    <target xsi:type="Null" name="blackhole" />

  </targets>

  <!-- ===================================================================
       Regras de roteamento (order matters — first match wins por padrão,
       mas usamos finalMinLevel para capturar tudo acima do limiar)
       =================================================================== -->
  <rules>

    <!-- NLog interno e ASP.NET / OWIN: só Warn ou acima no arquivo diário -->
    <logger name="Microsoft.*"    maxLevel="Info"  writeTo="blackhole" final="true" />
    <logger name="System.*"       maxLevel="Info"  writeTo="blackhole" final="true" />

    <!-- Integrações REST (VendasIntegrationClient + HttpClients) -->
    <logger name="ERPFinanceiro.Api.HttpClients.*"
            minLevel="Debug"
            writeTo="fileIntegracao,console"
            final="false" />

    <!-- Serviço de integração no Application layer -->
    <logger name="ERPFinanceiro.Application.Services.*"
            minLevel="Debug"
            writeTo="fileIntegracao,fileDaily,console"
            final="false" />

    <!-- Tudo mais: Info ou acima vai pro arquivo diário e console -->
    <logger name="*"
            minLevel="Info"
            writeTo="fileDaily,console" />

  </rules>

</nlog>
